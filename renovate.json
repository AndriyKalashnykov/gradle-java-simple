{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommitType(chore)"
  ],
  "enabledManagers": [
    "gradle",
    "gradle-wrapper",
    "dockerfile",
    "docker-compose",
    "github-actions",
    "custom.regex"
  ],
  "commitMessagePrefix": "chore(all): ",
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "platformAutomerge": true,
  "automerge": true,
  "automergeType": "branch",
  "automergeStrategy": "squash",
  "ignoreTests": false,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "minimumReleaseAge": "0 days"
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track act version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "ACT_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "nektos/act",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track nvm version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "NVM_VERSION\\s*:=\\s*(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "nvm-sh/nvm",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Track Gradle version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "GRADLE_VER\\s*:=\\s*(?<currentValue>[0-9.]+)"
      ],
      "depNameTemplate": "gradle",
      "datasourceTemplate": "gradle-version"
    },
    {
      "customType": "regex",
      "description": "Track Node.js major version in Makefile",
      "managerFilePatterns": ["/^Makefile$/"],
      "matchStrings": [
        "NODE_VERSION\\s*:=\\s*(?<currentValue>[0-9]+)"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version"
    }
  ],
  "packageRules": [
    {
      "description": "Group all non-major updates and automerge after checks pass",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest",
        "pin",
        "pinDigest",
        "lockFileMaintenance"
      ],
      "groupName": "all non-major"
    },
    {
      "description": "Wait 3 days before automerging major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "major updates",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Group GitHub Actions into one PR",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    },
    {
      "description": "Group Makefile tool versions",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "Makefile tools"
    },
    {
      "description": "Label Java packages",
      "matchCategories": [
        "java"
      ],
      "addLabels": [
        "lang: java"
      ]
    },
    {
      "description": "Group Apache Commons dependencies into one PR",
      "groupName": "Apache commons",
      "matchPackageNames": [
        "commons-io:commons-io",
        "/^org\\.apache\\.commons:/"
      ]
    },
    {
      "description": "Group annotation libraries",
      "groupName": "annotations",
      "matchPackageNames": [
        "com.google.errorprone:*",
        "net.jcip:jcip-annotations",
        "org.checkerframework:checker-qual",
        "org.jetbrains:annotations",
        "org.jspecify:jspecify"
      ]
    },
    {
      "description": "Group Docker base images",
      "matchDatasources": [
        "docker"
      ],
      "groupName": "Docker dependencies"
    }
  ]
}
