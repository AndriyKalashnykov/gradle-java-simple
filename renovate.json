{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":label(dependencies)",
    ":semanticCommitType(chore)",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    "replacements:all",
    "workarounds:all"
  ],
  "commitBody": "Signed-off-by: Renovate Bot <bot@renovateapp.com>",
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "prConcurrentLimit": 50,
  "prHourlyLimit": 0,
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "description": "Group all non-major updates and automerge after checks pass",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest", "lockFileMaintenance"],
      "groupName": "all non-major"
    },
    {
      "description": "Major updates: separate PRs, longer stabilization before automerge",
      "matchUpdateTypes": ["major"],
      "groupName": "major updates",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Pin actions/upload-artifact to v4 — v7 ESM migration breaks act, upgrade incrementally (v5→v6→v7) and test each with make ci-run",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["actions/upload-artifact"],
      "allowedVersions": "<=4",
      "automerge": false
    }
  ]
}
